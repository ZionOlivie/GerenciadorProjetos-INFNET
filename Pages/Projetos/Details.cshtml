@page
@model GerenciadorProjetos.Pages.Projetos.DetailsModel

@{
    ViewData["Title"] = "Detalhes do projeto";
}

<h1>Detalhes</h1>

<div>
    <h4>Projeto</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Título</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Projeto.Titulo)</dd>

        <dt class="col-sm-2">Descrição</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Projeto.Descricao)</dd>

        <dt class="col-sm-2">Data de Início</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Projeto.DataInicio)</dd>

        <dt class="col-sm-2">Prazo</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Projeto.DataPrazo)</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Projeto.Status)</dd>

        <dt class="col-sm-2">Gerente Responsável</dt>
        <dd class="col-sm-10">@Model.Projeto.Gerente?.Nome</dd>

        <dt class="col-sm-2">Equipe</dt>
        <dd class="col-sm-10">
            @if (Model.Projeto.Equipa != null && Model.Projeto.Equipa.Any())
            {
                <ul class="list-group list-group-flush col-md-6">
                    @foreach (var membro in Model.Projeto.Equipa)
                    {
                        <li class="list-group-item bg-transparent px-0">
                            👤 <b>@membro.Nome</b> <br />
                            <small class="text-muted">@membro.Email</small>
                        </li>
                    }
                </ul>
            }
            else
            {
                <span class="text-muted">Nenhum membro vinculado a este projeto.</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Projeto.Id" class="btn btn-secondary">Editar</a> |
    <a asp-page="./Index">Voltar para a Lista</a>
</div>